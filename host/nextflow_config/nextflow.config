/* docker.enabled = true */
profiles {
  hyperplane_singularity {
    process {
        withName: CDHIT {
            container = 'file:///$SINGULARITY_SIF_PATH/cd-hit-4-8-1.sif'
        }
        withName: CDHITTOTSV {
            container = 'file:///$SINGULARITY_SIF_PATH/cdhit-to-tsv.sif'
        }
        withName: EPIDOPE {
            container = 'file:///$SINGULARITY_SIF_PATH/epidope_v0.3.sif'
        }
        withName: BEPIPRED {
            container = 'file:///$SINGULARITY_SIF_PATH/iedb-b-cell_latest.sif'
        }
       withName: BEPIPREDTOTSV {
            container = 'file:///$SINGULARITY_SIF_PATH/bepipred-to-tsv_latest.sif'
        }
       withName: DISCOTOPE {
            container = 'file:///$SINGULARITY_SIF_PATH/discotope_1.1.sif'
        }
       withName: DISCOTOPETOTSV {
            container = 'file:///$SINGULARITY_SIF_PATH/discotope_to_tsv_latest.sif'
        }
       withName: NETMHCPANIEDB {
            container = 'file:///$SINGULARITY_SIF_PATH/iedb-mhc-i_latest.sif'
        }
      withName: NETMHCPANI {
            container = 'file:///$SINGULARITY_SIF_PATH/netmhcpan_i_4.1.sif'
        }
      withName : NETMHCPANIIEDB {
            container = 'file:///$SINGULARITY_SIF_PATH/iedb-mhc-ii_latest.sif'
        }
      // PATCH (dengue fork): upstream had two issues here.
      // (1) The block name was duplicated as NETMHCPANI (same as line 29)
      //     so this block silently overwrote the class-I container with a
      //     class-II SIF path. Renamed to NETMHCPANII.
      // (2) The key `conainer` was a typo for `container`, which Nextflow
      //     silently ignored, leaving the class-II process with no
      //     container assignment.
      withName: NETMHCPANII {
            container = 'file:///$SINGULARITY_SIF_PATH/netmhcpan_ii_4.1.sif'
        }
      withName: SPLITFASTAS {
            container = 'file:///$SINGULARITY_SIF_PATH/split_fastas_latest.sif'
        }
      withName: TCRPMHC {
            container = 'file:///$SINGULARITY_SIF_PATH/tcrpmhc_1.0.sif'
        }
      withName: PDBEPISA {
            container = 'file:///$SINGULARITY_SIF_PATH/pisa_server_latest.sif'
        }
      withName: BLASTFROMFILES {
              container = 'file:///$SINGULARITY_SIF_PATH/blast_latest.sif'
        }
      withName: CLUSTALOMEGAMSA {
              container = 'file:///$SINGULARITY_SIF_PATH/clustalomega_latest.sif'
        }
    }
    singularity {
        enabled = true
        // PATCH (dengue fork): apptainer/singularity by default bind-mounts
        // the host user's $HOME into the container, which shadows the
        // container's pip site-packages with whatever the host has in
        // ~/.local. For Pete's older containers (pandas 1.4 era) this
        // causes np.bool AttributeError because the host has numpy>=1.24.
        // --no-home prevents the home-mount; --containall isolates further.
        runOptions = '--no-home --containall --bind /data:/data'
        autoMounts = true
    }
  }
}
